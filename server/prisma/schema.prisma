generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Board {
  id             String    @id @default(cuid())
  title          String
  description    String?
  icon           String? // optional lucide icon name
  color          String? // optional accent color (hex)
  isArchived     Boolean   @default(false)
  ownerId        String?
  owner          User?     @relation(fields: [ownerId], references: [id], onDelete: Cascade, name: "BoardOwner")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // Tracks last meaningful change (note edited, member added, …) for sorting
  // and "recent activity" surfaces, independent of schema-level updatedAt.
  lastActivityAt DateTime?

  notes      Note[]
  members    BoardMember[]
  stars      BoardStar[]
  activities Activity[]
  comments   Comment[]
  invites    Invite[]

  @@index([ownerId])
  @@index([isArchived])
}

// Pending invitation to a board for an email that has no account yet (or an
// existing user who hasn't accepted). Consumed when the invitee registers with
// the matching email or opens the tokenized accept link while signed in.
model Invite {
  id          String    @id @default(cuid())
  boardId     String
  email       String
  role        String    @default("editor")
  token       String    @unique @default(cuid())
  invitedById String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  acceptedAt  DateTime?

  board     Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  invitedBy User? @relation("InviteInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([boardId, email])
  @@index([email])
}

model Note {
  id      String @id @default(cuid())
  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  text      String   @default("")
  x         Int      @default(100)
  y         Int      @default(100)
  width     Int      @default(180)
  height    Int      @default(120)
  color     String   @default("#fde047") // yellow-300
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  reactions Reaction[]

  @@index([boardId])
}

// Threaded discussion attached to a single note.
model Comment {
  id        String   @id @default(cuid())
  boardId   String
  noteId    String
  authorId  String?
  text      String
  createdAt DateTime @default(now())

  board  Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  note   Note  @relation(fields: [noteId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([noteId, createdAt])
  @@index([boardId])
}

// Emoji reaction on a note. One row per (note, user, emoji).
model Reaction {
  id        String   @id @default(cuid())
  noteId    String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId, emoji])
  @@index([noteId])
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  name                   String?
  password               String // bcrypt hash
  avatarUrl              String?
  // Free-form JSON for UI preferences (theme is also persisted client-side).
  preferences            Json?
  // TOTP two-factor auth. Secret is stored once setup begins; `enabled` flips
  // true only after the user verifies a code from their authenticator app.
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String?
  // Bcrypt-hashed single-use recovery codes, consumed one-by-one at sign-in
  // when the authenticator device is unavailable.
  twoFactorRecoveryCodes String[]  @default([])
  // Stripe billing. plan is the entitlement tier ("free" | "pro" | "team");
  // subscriptionStatus mirrors Stripe's subscription.status.
  stripeCustomerId       String?   @unique
  plan                   String    @default("free")
  subscriptionStatus     String?
  currentPeriodEnd       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  boards        Board[]        @relation("BoardOwner")
  members       BoardMember[]
  stars         BoardStar[]
  notifications Notification[] @relation("NotificationRecipient")
  activities    Activity[]
  comments      Comment[]
  reactions     Reaction[]
  sentInvites   Invite[]       @relation("InviteInvitedBy")
}

model BoardMember {
  id        String   @id @default(cuid())
  boardId   String
  userId    String
  role      String   @default("member") // possible values: "member", "editor", "viewer", etc.
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

// Favorites / starred boards (per user).
model BoardStar {
  id        String   @id @default(cuid())
  userId    String
  boardId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([userId, boardId])
  @@index([userId])
  @@index([boardId])
}

// Append-only activity log feeding the dashboard and board activity panel.
model Activity {
  id        String   @id @default(cuid())
  boardId   String
  actorId   String?
  type      String // e.g. board.created, member.added, note.created
  meta      Json?
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([boardId, createdAt])
  @@index([createdAt])
}

// Per-user notification feed (invites, mentions, workspace updates).
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // invite, member_added, mention, board_update
  boardId   String?
  actorId   String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// Starter templates surfaced in the gallery / command palette.
model Template {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  category    String
  description String
  thumbnail   String?
  // Blueprint of notes (and later shapes) to clone into a new board.
  blueprint   Json
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}
