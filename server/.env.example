# ---- Core ----
# Secret used to sign JWTs. Generate one with: node generate-jwt-secret.js
JWT_SECRET=

# PostgreSQL connection strings. DATABASE_URL is the pooled/runtime URL;
# DIRECT_URL is the direct (non-pooled) URL Prisma uses for migrations.
DATABASE_URL=
DIRECT_URL=

# Public URL of the client app. Used for CORS and Stripe redirect/return URLs.
# Defaults to http://localhost:5173 in development.
FRONTEND_URL=http://localhost:5173

# Optional: "production" enables trust-proxy + production CORS origins.
NODE_ENV=development

# Optional: port the API listens on (defaults to 4000).
PORT=4000

# ---- Billing (Stripe) ----
# Leave these blank to run without billing — the billing endpoints will return
# a graceful 503 and the Settings → Billing UI shows a "not configured" note.
STRIPE_SECRET_KEY=
# Signing secret for the webhook endpoint (POST /api/billing/webhook).
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs for the paid plans (from the Stripe dashboard).
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
