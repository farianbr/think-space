# ---- Voice room (WebRTC) ----
# Optional TURN server for the voice room. STUN works for most networks, but
# restrictive/symmetric NATs need TURN to connect. Leave blank to use STUN only.
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=